---
import "../styles/global.css";

const { title = "I.E. Luis Fabio Xammar" } = Astro.props;
---

<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <link rel="icon" type="image/png" href="/favicon.png?v=2" />

    <title>{title}</title>
  </head>

  <body class="bg-[#0B2344] text-white">
    <slot />
  </body>
</html>