---
const currentPath = Astro.url.pathname;

const links = [
  { href: "/", label: "Inicio" },
  { href: "/nosotros", label: "Nosotros" },
  { href: "/noticias", label: "Noticias y comunicados" },
  { href: "/galeria", label: "Galería" },
  { href: "/contacto", label: "Contacto" },
  { href: "/matricula", label: "Matrícula" },
];

const isActive = (href: string) => {
  if (href === "/") {
    return currentPath === "/";
  }

  return currentPath.startsWith(href);
};
---

<header class="fixed top-0 left-0 w-full z-50 bg-[#0B2344]/90 backdrop-blur border-b border-white/10">
  <nav class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">
    <a href="/" class="flex items-center gap-3">
      <div class="w-12 h-12 rounded-full bg-white p-1 flex items-center justify-center overflow-hidden">
        <img
            src="/img/insigniaxammar.jpg"
            alt="Insignia I.E. Luis Fabio Xammar"
            class="w-full h-full object-contain"
        />
      </div>

      <div class="leading-tight">
        <p class="text-sm font-bold text-white">I.E. Luis Fabio</p>
        <p class="text-xs font-semibold text-[#60B5E8]">Xammar</p>
      </div>
    </a>

    <div class="hidden md:flex items-center gap-7 text-sm">
      {
        links.map((link) => (
          <a
            href={link.href}
            class={`transition ${
              isActive(link.href)
                ? "text-[#60B5E8] font-semibold"
                : "text-slate-300 hover:text-white"
            }`}
          >
            {link.label}
          </a>
        ))
      }
    </div>

    <a
      href="/login"
      class={`hidden md:inline-block px-4 py-2 rounded-xl text-sm font-semibold transition ${
        isActive("/login")
          ? "bg-[#60B5E8] text-[#0B2344]"
          : "bg-[#2F8FC9] hover:bg-[#60B5E8] text-white hover:text-[#0B2344]"
      }`}
    >
      Ingresar
    </a>

    <button
      id="btn-menu"
      class="md:hidden text-white text-3xl"
      aria-label="Abrir menú"
    >
      ☰
    </button>
  </nav>

  <div
    id="menu-mobile"
    class="hidden md:hidden bg-[#0B2344] border-t border-white/10 px-6 py-5"
  >
    <div class="flex flex-col gap-4 text-sm">
      {
        links.map((link) => (
          <a
            href={link.href}
            class={`transition ${
              isActive(link.href)
                ? "text-[#60B5E8] font-semibold"
                : "text-slate-300 hover:text-white"
            }`}
          >
            {link.label}
          </a>
        ))
      }

      <a
        href="/login"
        class={`px-4 py-3 rounded-xl text-sm font-semibold text-center transition ${
          isActive("/login")
            ? "bg-[#60B5E8] text-[#0B2344]"
            : "bg-[#2F8FC9] hover:bg-[#60B5E8] text-white hover:text-[#0B2344]"
        }`}
      >
        Ingresar
      </a>
    </div>
  </div>
</header>

<script>
  const btnMenu = document.getElementById("btn-menu");
  const menuMobile = document.getElementById("menu-mobile");

  btnMenu?.addEventListener("click", () => {
    menuMobile?.classList.toggle("hidden");

    if (btnMenu.textContent === "☰") {
      btnMenu.textContent = "×";
    } else {
      btnMenu.textContent = "☰";
    }
  });
</script>