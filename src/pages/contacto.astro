---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith("/") ? rawBase : `${rawBase}/`;
---

<Layout title="Contacto | I.E. Luis Fabio Xammar">
  <Navbar />

  <main class="min-h-screen pt-32 bg-gradient-to-br from-[#0B2344] via-[#123C73] to-[#0B2344]">
    <!-- ENCABEZADO -->
    <section class="px-6 pb-20">
      <div class="max-w-6xl mx-auto grid md:grid-cols-2 gap-12 items-center">
        <div>
          <p class="text-[#60B5E8] font-semibold mb-4">
            Contacto institucional
          </p>

          <h1 class="text-4xl md:text-6xl font-bold leading-tight mb-6">
            Comunícate con la I.E. Luis Fabio Xammar
          </h1>

          <p class="text-slate-200 text-lg leading-relaxed mb-8">
            Estamos para atender consultas sobre matrícula, comunicados,
            actividades institucionales, horarios y orientación general para
            estudiantes, padres de familia y apoderados.
          </p>

          <div class="flex flex-col sm:flex-row gap-4">
            <a
              href="#formulario-contacto"
              class="bg-[#2F8FC9] hover:bg-[#60B5E8] text-white hover:text-[#0B2344] px-6 py-3 rounded-xl font-semibold transition text-center"
            >
              Enviar mensaje
            </a>

            <a
              href="#ubicacion"
              class="border border-white/30 hover:bg-white/10 px-6 py-3 rounded-xl font-semibold transition text-center"
            >
              Ver ubicación
            </a>
          </div>
        </div>

        <div class="relative bg-white/10 border border-white/10 rounded-3xl p-6 shadow-2xl overflow-hidden">
          <div class="absolute -top-20 -right-20 w-52 h-52 bg-[#60B5E8]/30 rounded-full blur-3xl"></div>
          <div class="absolute -bottom-20 -left-20 w-52 h-52 bg-white/20 rounded-full blur-3xl"></div>

          <div class="relative bg-white rounded-2xl p-8 text-center text-[#0B2344]">
            <div class="w-24 h-24 mx-auto rounded-2xl bg-[#2F8FC9] flex items-center justify-center text-4xl mb-6">
              📍
            </div>

            <h2 class="text-2xl md:text-3xl font-extrabold mb-3">
              Ubicación y atención
            </h2>

            <p class="text-slate-600">
              Encuentra nuestra ubicación y canales de contacto institucional.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- INFORMACIÓN DE CONTACTO -->
    <section class="px-6 py-20 bg-[#0B2344]">
      <div class="max-w-6xl mx-auto">
        <div class="text-center mb-12">
          <p class="text-[#60B5E8] font-semibold mb-3">
            Canales de atención
          </p>

          <h2 class="text-3xl md:text-4xl font-bold">
            Información de contacto
          </h2>

          <p class="text-slate-300 mt-4 max-w-3xl mx-auto">
            Puedes comunicarte con la institución mediante los siguientes medios.
            Actualiza estos datos con la información oficial del colegio.
          </p>
        </div>

        <div class="grid md:grid-cols-3 gap-6">
          <div class="bg-white/10 border border-white/10 rounded-3xl p-6">
            <div class="w-14 h-14 rounded-2xl bg-[#2F8FC9] flex items-center justify-center text-2xl mb-5">
              📍
            </div>

            <h3 class="text-2xl font-bold mb-3">
              Dirección
            </h3>

            <p class="text-slate-300">
              Au. Panamericana N, Huacho 15137, Perú
            </p>
          </div>

          <div class="bg-white/10 border border-white/10 rounded-3xl p-6">
            <div class="w-14 h-14 rounded-2xl bg-[#2F8FC9] flex items-center justify-center text-2xl mb-5">
              ☎️
            </div>

            <h3 class="text-2xl font-bold mb-3">
              Teléfono
            </h3>

            <p class="text-slate-300">
              982 511 250
            </p>
          </div>

          <div class="bg-white/10 border border-white/10 rounded-3xl p-6">
            <div class="w-14 h-14 rounded-2xl bg-[#2F8FC9] flex items-center justify-center text-2xl mb-5">
              ✉️
            </div>

            <h3 class="text-2xl font-bold mb-3">
              Correo
            </h3>

            <p class="text-slate-300">
              colegio@ejemplo.com
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- FORMULARIO Y HORARIO -->
    <section id="formulario-contacto" class="px-6 py-20 bg-gradient-to-br from-[#123C73] to-[#0B2344]">
      <div class="max-w-6xl mx-auto grid lg:grid-cols-2 gap-8">
        <form
          id="form-contacto"
          class="bg-white/10 border border-white/10 rounded-3xl p-8 space-y-4"
        >
          <div class="mb-6">
            <p class="text-[#60B5E8] font-semibold mb-3">
              Escríbenos
            </p>

            <h2 class="text-3xl font-bold">
              Enviar mensaje
            </h2>

            <p class="text-slate-300 mt-3">
              Completa el formulario y tu mensaje quedará registrado para que la
              institución pueda revisarlo.
            </p>
          </div>

          <input
            id="nombre"
            type="text"
            placeholder="Nombre completo"
            class="w-full px-4 py-3 rounded-xl bg-[#0B2344] border border-white/10 outline-none focus:border-[#60B5E8]"
            required
          />

          <input
            id="correo"
            type="email"
            placeholder="Correo electrónico"
            class="w-full px-4 py-3 rounded-xl bg-[#0B2344] border border-white/10 outline-none focus:border-[#60B5E8]"
            required
          />

          <input
            id="asunto"
            type="text"
            placeholder="Asunto"
            class="w-full px-4 py-3 rounded-xl bg-[#0B2344] border border-white/10 outline-none focus:border-[#60B5E8]"
            required
          />

          <textarea
            id="mensaje"
            placeholder="Mensaje"
            rows="5"
            class="w-full px-4 py-3 rounded-xl bg-[#0B2344] border border-white/10 outline-none focus:border-[#60B5E8]"
            required
          ></textarea>
          <label class="flex items-start gap-3 text-sm text-slate-300">
            <input
              id="acepta-privacidad"
              type="checkbox"
              class="mt-1"
              required
            />

            <span>
              Acepto la
              <a href={`${base}privacidad/`} class="text-[#60B5E8] hover:underline">
                Política de Privacidad
              </a>
              y autorizo el uso de mis datos para responder mi consulta.
            </span>
          </label>
          <div class="bg-[#0B2344] border border-white/10 rounded-2xl p-4">
            <p class="text-sm text-slate-300 leading-relaxed">
              Si eres estudiante menor de edad, realiza tu consulta con conocimiento de tu
              padre, madre o apoderado. No envíes DNI, dirección exacta, datos médicos ni
              documentos personales mediante este formulario.
            </p>
          </div>

          <button
            id="btn-enviar"
            type="submit"
            class="w-full bg-[#2F8FC9] hover:bg-[#60B5E8] text-white hover:text-[#0B2344] px-6 py-3 rounded-xl font-semibold transition disabled:opacity-60 disabled:cursor-not-allowed"
          >
            Enviar mensaje
          </button>

          <p id="estado-formulario" class="text-center text-sm"></p>
        </form>

        <div class="bg-white rounded-3xl p-8 text-[#0B2344]">
          <p class="font-semibold text-[#2F8FC9] mb-3">
            Horario de atención
          </p>

          <h2 class="text-3xl font-extrabold mb-6">
            Atención institucional
          </h2>

          <div class="space-y-4">
            <div class="bg-slate-100 rounded-2xl p-5">
              <h3 class="font-bold mb-2">Lunes a viernes</h3>
              <p class="text-slate-600">
                08:00 a.m. - 12:00 p.m.
              </p>
            </div>

            <div class="bg-slate-100 rounded-2xl p-5">
              <h3 class="font-bold mb-2">Consultas frecuentes</h3>
              <p class="text-slate-600">
                Matrícula, horarios, comunicados, actividades y orientación a
                padres de familia.
              </p>
            </div>

            <div class="bg-slate-100 rounded-2xl p-5">
              <h3 class="font-bold mb-2">Recomendación</h3>
              <p class="text-slate-600">
                Verifica siempre los comunicados oficiales publicados en la
                sección de noticias.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- MAPA -->
    <section id="ubicacion" class="px-6 py-20 bg-[#0B2344]">
      <div class="max-w-6xl mx-auto">
        <div class="mb-10">
          <p class="text-[#60B5E8] font-semibold mb-3">
            Ubicación
          </p>

          <h2 class="text-3xl md:text-4xl font-bold mb-4">
            Encuéntranos en el mapa
          </h2>

          <p class="text-slate-300 max-w-3xl">
            La ubicación mostrada corresponde a la búsqueda de la I.E.E. Luis
            Fabio Xammar Jurado en Huacho. Puedes ajustar la dirección exacta
            si el colegio desea mostrar una referencia oficial diferente.
          </p>
        </div>

        <div class="bg-white/10 border border-white/10 rounded-3xl p-4 shadow-2xl">
          <div class="overflow-hidden rounded-2xl">
            <iframe
              title="Ubicación I.E. Luis Fabio Xammar"
              src="https://www.google.com/maps?q=I.E.E.%20Luis%20Fabio%20Xammar%20Jurado%20Huacho%20Peru&output=embed"
              class="w-full h-[420px] border-0"
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
            ></iframe>
          </div>
        </div>

        <div class="mt-8 flex flex-col sm:flex-row gap-4">
          <a
            href="https://www.google.com/maps/search/?api=1&query=I.E.E.%20Luis%20Fabio%20Xammar%20Jurado%20Huacho%20Peru"
            target="_blank"
            rel="noopener noreferrer"
            class="bg-[#2F8FC9] hover:bg-[#60B5E8] text-white hover:text-[#0B2344] px-6 py-3 rounded-xl font-semibold transition text-center"
          >
            Abrir en Google Maps
          </a>

          <a
            href={`${base}matricula/`}
            class="border border-white/30 hover:bg-white/10 px-6 py-3 rounded-xl font-semibold transition text-center"
          >
            Ver matrícula
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
<script>
  import {
    addDoc,
    collection,
    serverTimestamp,
  } from "firebase/firestore";

  import { db } from "../firebase/config.js";

  const formContacto = document.getElementById("form-contacto");
  const nombreInput = document.getElementById("nombre");
  const correoInput = document.getElementById("correo");
  const asuntoInput = document.getElementById("asunto");
  const mensajeInput = document.getElementById("mensaje");
  const btnEnviar = document.getElementById("btn-enviar");
  const estadoFormulario = document.getElementById("estado-formulario");
  const aceptaPrivacidadInput = document.getElementById("acepta-privacidad");

  const mostrarEstado = (texto, tipo = "info") => {
    if (!(estadoFormulario instanceof HTMLParagraphElement)) return;

    estadoFormulario.textContent = texto;

    if (tipo === "ok") {
      estadoFormulario.className = "text-center text-sm text-green-300";
    } else if (tipo === "error") {
      estadoFormulario.className = "text-center text-sm text-red-300";
    } else {
      estadoFormulario.className = "text-center text-sm text-slate-300";
    }
  };

  if (
    formContacto instanceof HTMLFormElement &&
    nombreInput instanceof HTMLInputElement &&
    correoInput instanceof HTMLInputElement &&
    asuntoInput instanceof HTMLInputElement &&
    mensajeInput instanceof HTMLTextAreaElement &&
    aceptaPrivacidadInput instanceof HTMLInputElement &&
    btnEnviar instanceof HTMLButtonElement
  ) {
    formContacto.addEventListener("submit", async (e) => {
      e.preventDefault();

      const nombre = nombreInput.value.trim();
      const correo = correoInput.value.trim();
      const asunto = asuntoInput.value.trim();
      const mensaje = mensajeInput.value.trim();

      if (!nombre || !correo || !asunto || !mensaje) {
        mostrarEstado("Completa todos los campos.", "error");
        return;
      }
      if (!aceptaPrivacidadInput.checked) {
        mostrarEstado("Debes aceptar la Política de Privacidad.", "error");
        return;
      }

      btnEnviar.disabled = true;
      btnEnviar.textContent = "Enviando...";
      mostrarEstado("Enviando mensaje...", "info");

      try {
        await addDoc(collection(db, "mensajes"), {
          nombre,
          correo,
          asunto,
          mensaje,
          estado: "nuevo",
          fechaCreacion: serverTimestamp(),
        });

        formContacto.reset();
        mostrarEstado("Mensaje enviado correctamente.", "ok");
      } catch (error) {
        console.error(error);
        mostrarEstado("No se pudo enviar el mensaje. Inténtalo nuevamente.", "error");
      } finally {
        btnEnviar.disabled = false;
        btnEnviar.textContent = "Enviar mensaje";
      }
    });
  }
</script>
