---
const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith("/") ? rawBase : `${rawBase}/`;

const currentPath = Astro.url.pathname;
const links = [
  { href: base, label: "Inicio" },
  { href: `${base}nosotros/`, label: "Nosotros" },
  { href: `${base}noticias/`, label: "Noticias y comunicados" },
  { href: `${base}galeria/`, label: "Galería" },
  { href: `${base}contacto/`, label: "Contacto" },
  { href: `${base}matricula/`, label: "Matrícula" },
];

const isActive = (href) => {
  if (href === base) {
    return currentPath === base;
  }

  return currentPath.startsWith(href);
};
---

<header class="fixed top-0 left-0 w-full z-50 bg-[#0B2344]/95 backdrop-blur-xl border-b border-white/10">
  <nav class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">
    <a href={base} class="flex items-center gap-3">
      <div class="w-12 h-12 rounded-full bg-white p-1 flex items-center justify-center overflow-hidden">
        <img
          src={`${base}img/insigniaxammar.jpg`}
          alt="Insignia I.E. Luis Fabio Xammar"
          class="w-full h-full object-contain"
        />
      </div>

      <div class="leading-tight">
        <p class="font-bold text-white">
          I.E. Luis Fabio
        </p>

        <p class="text-sm text-[#60B5E8] font-semibold">
          Xammar
        </p>
      </div>
    </a>

    <div class="hidden lg:flex items-center gap-8">
      {
        links.map((link) => (
          <a
            href={link.href}
            class={`text-sm font-medium transition ${
              isActive(link.href)
                ? "text-[#60B5E8]"
                : "text-slate-200 hover:text-[#60B5E8]"
            }`}
          >
            {link.label}
          </a>
        ))
      }
    </div>

    <div class="hidden lg:block">
      <a
        href={`${base}login/`}
        class="bg-[#2F8FC9] hover:bg-[#60B5E8] text-white hover:text-[#0B2344] px-5 py-3 rounded-xl font-semibold transition"
      >
        Ingresar
      </a>
    </div>

    <button
      id="btn-menu"
      class="lg:hidden w-11 h-11 rounded-xl bg-white/10 border border-white/10 flex items-center justify-center text-2xl"
      aria-label="Abrir menú"
    >
      ☰
    </button>
  </nav>

  <div
    id="menu-mobile"
    class="hidden lg:hidden bg-[#0B2344] border-t border-white/10 px-6 pb-6"
  >
    <div class="flex flex-col gap-4 pt-4">
      {
        links.map((link) => (
          <a
            href={link.href}
            class={`font-medium transition ${
              isActive(link.href)
                ? "text-[#60B5E8]"
                : "text-slate-200 hover:text-[#60B5E8]"
            }`}
          >
            {link.label}
          </a>
        ))
      }

      <a
        href={`${base}login/`}
        class="bg-[#2F8FC9] hover:bg-[#60B5E8] text-white hover:text-[#0B2344] px-5 py-3 rounded-xl font-semibold transition text-center"
      >
        Ingresar
      </a>
    </div>
  </div>
</header>

<script>
  const btnMenu = document.getElementById("btn-menu");
  const menuMobile = document.getElementById("menu-mobile");

  if (btnMenu instanceof HTMLButtonElement && menuMobile instanceof HTMLDivElement) {
    btnMenu.addEventListener("click", () => {
      menuMobile.classList.toggle("hidden");

      btnMenu.textContent = menuMobile.classList.contains("hidden")
        ? "☰"
        : "×";
    });
  }
</script>