---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Hero from "../components/Hero.astro";
import Footer from "../components/Footer.astro";
---

<Layout title="Inicio | I.E. Luis Fabio Xammar">
  <Navbar />

  <Hero />

  <section class="px-6 py-20 bg-[#0B2344]">
    <div class="max-w-6xl mx-auto">
      <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-4 mb-10">
        <div>
          <p class="text-[#60B5E8] font-semibold mb-3">
            Información institucional
          </p>

          <h2 class="text-3xl md:text-4xl font-bold">
            Últimas noticias y comunicados
          </h2>

          <p class="text-slate-300 mt-4 max-w-2xl">
            Revisa los comunicados, avisos, actividades y eventos más recientes
            publicados por la institución.
          </p>
        </div>

        <a
          href="/noticias"
          class="bg-[#2F8FC9] hover:bg-[#60B5E8] text-white hover:text-[#0B2344] px-5 py-3 rounded-xl font-semibold transition text-center"
        >
          Ver todas
        </a>
      </div>

      <div id="estado-ultimas-noticias" class="text-slate-300">
        Cargando últimas noticias...
      </div>

      <div
        id="ultimas-noticias"
        class="grid md:grid-cols-3 gap-6"
      ></div>
    </div>
  </section>

  <section class="px-6 py-20 bg-gradient-to-br from-[#123C73] to-[#0B2344]">
    <div class="max-w-6xl mx-auto grid md:grid-cols-3 gap-6">
      <div class="bg-white/10 border border-white/10 rounded-3xl p-6">
        <div class="w-14 h-14 rounded-2xl bg-[#2F8FC9] flex items-center justify-center text-2xl mb-5">
          📘
        </div>

        <h3 class="text-2xl font-bold mb-3">
          Formación académica
        </h3>

        <p class="text-slate-300">
          Promovemos el aprendizaje, la responsabilidad y el desarrollo de
          capacidades para el futuro.
        </p>
      </div>

      <div class="bg-white/10 border border-white/10 rounded-3xl p-6">
        <div class="w-14 h-14 rounded-2xl bg-[#2F8FC9] flex items-center justify-center text-2xl mb-5">
          🤝
        </div>

        <h3 class="text-2xl font-bold mb-3">
          Valores
        </h3>

        <p class="text-slate-300">
          Fomentamos respeto, disciplina, identidad, compromiso y convivencia
          dentro de la comunidad educativa.
        </p>
      </div>

      <div class="bg-white/10 border border-white/10 rounded-3xl p-6">
        <div class="w-14 h-14 rounded-2xl bg-[#2F8FC9] flex items-center justify-center text-2xl mb-5">
          🏫
        </div>

        <h3 class="text-2xl font-bold mb-3">
          Identidad xammarina
        </h3>

        <p class="text-slate-300">
          Fortalecemos el orgullo institucional y la participación activa de
          estudiantes, docentes y familias.
        </p>
      </div>
    </div>
  </section>

  <section class="px-6 py-20 bg-[#0B2344]">
    <div class="max-w-6xl mx-auto bg-white rounded-3xl p-8 md:p-12 text-[#0B2344] grid md:grid-cols-2 gap-8 items-center">
      <div>
        <p class="font-semibold text-[#2F8FC9] mb-3">
          Matrícula e información
        </p>

        <h2 class="text-3xl md:text-4xl font-extrabold mb-4">
          ¿Necesitas información sobre matrícula?
        </h2>

        <p class="text-slate-700">
          Consulta los requisitos, fechas, documentos y orientación para el
          proceso de matrícula de la institución.
        </p>
      </div>

      <div class="flex flex-col sm:flex-row gap-4 md:justify-end">
        <a
          href="/matricula"
          class="bg-[#2F8FC9] hover:bg-[#60B5E8] text-white hover:text-[#0B2344] px-6 py-3 rounded-xl font-semibold transition text-center"
        >
          Ver matrícula
        </a>

        <a
          href="/contacto"
          class="border border-[#0B2344]/20 hover:bg-slate-100 px-6 py-3 rounded-xl font-semibold transition text-center"
        >
          Contactar
        </a>
      </div>
    </div>
  </section>

  <Footer />
</Layout>

<script>
  import {
    collection,
    getDocs,
    limit,
    orderBy,
    query,
  } from "firebase/firestore";

  import { db } from "../firebase/config.js";

  const estadoUltimasNoticias = document.getElementById("estado-ultimas-noticias");
  const contenedorUltimasNoticias = document.getElementById("ultimas-noticias");

  const formatearFecha = (fechaFirebase) => {
    if (!fechaFirebase || typeof fechaFirebase.toDate !== "function") {
      return "Fecha no disponible";
    }

    const fecha = fechaFirebase.toDate();

    return fecha.toLocaleDateString("es-PE", {
      day: "2-digit",
      month: "long",
      year: "numeric",
    });
  };

  const cargarUltimasNoticias = async () => {
    if (!(estadoUltimasNoticias instanceof HTMLDivElement)) return;
    if (!(contenedorUltimasNoticias instanceof HTMLDivElement)) return;

    try {
      const consulta = query(
        collection(db, "noticias"),
        orderBy("fechaCreacion", "desc"),
        limit(3)
      );

      const resultado = await getDocs(consulta);

      if (resultado.empty) {
        estadoUltimasNoticias.textContent =
          "Todavía no hay noticias publicadas.";
        return;
      }

      estadoUltimasNoticias.classList.add("hidden");
      contenedorUltimasNoticias.innerHTML = "";

      resultado.forEach((documento) => {
        const noticia = documento.data();

        const tarjeta = document.createElement("article");

        tarjeta.className =
          "bg-white/10 border border-white/10 rounded-2xl p-6 hover:bg-white/15 transition";

        tarjeta.innerHTML = `
          ${
            noticia.imagen
              ? `<img
                  src="${noticia.imagen}"
                  alt="${noticia.titulo || "Noticia"}"
                  class="w-full h-44 object-cover rounded-xl mb-5"
                />`
              : ""
          }

          <p class="text-sm text-[#60B5E8] mb-2 font-semibold">
            ${noticia.categoria || "Noticia"}
          </p>

          <h3 class="text-xl font-bold mb-3">
            ${noticia.titulo || "Sin título"}
          </h3>

          <p class="text-slate-300 mb-5 line-clamp-3">
            ${noticia.descripcion || "Sin descripción"}
          </p>

          <p class="text-xs text-slate-400">
            Publicado: ${formatearFecha(noticia.fechaCreacion)}
          </p>
        `;

        contenedorUltimasNoticias.appendChild(tarjeta);
      });
    } catch (error) {
      console.error(error);

      estadoUltimasNoticias.textContent =
        "No se pudieron cargar las últimas noticias.";

      estadoUltimasNoticias.className = "text-red-300";
    }
  };

  cargarUltimasNoticias();
</script>